# Copy to `.env` and fill in. NEVER commit the real `.env` (it is gitignored).
# Milestone projects read keys from their own `.env`; this template lists the
# providers used across the roadmap.

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Optional: open-model / hosted inference (used from Milestone 3/5) ---
TOGETHER_API_KEY=
GROQ_API_KEY=

# --- Optional: embeddings / rerank (Milestone 2) ---
VOYAGE_API_KEY=

# --- Optional: observability (Milestone 4) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
